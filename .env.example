# Copy to .env and adjust before: docker compose up -d --build

# Your domain (Caddy will get HTTPS automatically)
DOMAIN=tanibergen.me

# Email for Let's Encrypt certificate notifications
ACME_EMAIL=you@example.com

# Must match DOMAIN with https:// after Caddy is running
CORS_ORIGINS=https://tanibergen.me,https://www.tanibergen.me

# JWT secret — generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production

# Admin account created on first run
ADMIN_EMAIL=admin@rnmc.kz
ADMIN_PASSWORD=change-me

# Optional: JWT lifetime in minutes (default 480)
# JWT_EXPIRES_MINUTES=480

# Leave empty — frontend uses /api on the same domain via nginx
VITE_API_URL=

# Optional: override official NCT file URLs (defaults are correct as of 2024)
# NCT_URL=https://testcenter.kz/wp-content/uploads/2025/01/1-...xlsx
# GOP_URL=https://testcenter.kz/wp-content/uploads/2025/01/2-...xlsx
